# FastAPI backend environment variables
# Copy to .env and fill in real values

# PostgreSQL via Supabase (use the Pooler/pgbouncer URL for connection pooling)
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Groq API Key (from console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# JWT Secret — minimum 32 characters, keep secret
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars!!

# Your deployed Vercel frontend URL (set after Vercel deploy)
FRONTEND_URL=https://securewealth-twin.vercel.app
